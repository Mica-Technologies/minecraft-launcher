{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Package App",
      "type": "shell",
      "command": "mvn",
      "args": ["package"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
