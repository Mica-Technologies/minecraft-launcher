<GridPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="475.0" minWidth="750.0"
          prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane hero-surface"
          xmlns="http://javafx.com/javafx/16" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    </rowConstraints>
    <GridPane maxWidth="480.0" minWidth="380.0" prefWidth="460.0" styleClass="card elevated,progressCard" GridPane.halignment="CENTER" GridPane.valignment="CENTER">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints fillHeight="false" maxHeight="1.7976931348623157E308" minHeight="280.0" prefHeight="380.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <GridPane prefHeight="420.0" prefWidth="460.0" GridPane.halignment="CENTER" GridPane.valignment="CENTER">
            <padding><Insets top="8.0" bottom="8.0"/></padding>
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <!-- Row 0: Voxel cluster accent (Minecraft-themed iso cubes, animated bounce). Bumped a
                     few px taller than the static-cube layout to give the bounce travel room without
                     clipping at the top edge of the row. -->
                <RowConstraints fillHeight="false" maxHeight="92.0" minHeight="72.0" prefHeight="84.0" />
                <!-- Row 1: Upper label (overall task title, e.g. "Launching: Forge 1.15.2") -->
                <RowConstraints fillHeight="false" maxHeight="50.0" minHeight="35.0" prefHeight="42.0" />
                <!-- Row 2: Section label (current step, e.g. "Downloading mods...") -->
                <RowConstraints fillHeight="false" maxHeight="34.0" minHeight="22.0" prefHeight="30.0" />
                <!-- Row 3: Progress bar -->
                <RowConstraints fillHeight="false" maxHeight="35.0" minHeight="25.0" prefHeight="30.0" />
                <!-- Row 4: Detail label (file-level info below progress bar) -->
                <RowConstraints fillHeight="false" maxHeight="35.0" minHeight="20.0" prefHeight="28.0" />
                <!-- Row 5: Speed/ETA info label -->
                <RowConstraints fillHeight="false" maxHeight="25.0" minHeight="15.0" prefHeight="22.0" />
            </rowConstraints>

            <!-- Row 0: Minecraft-themed iso-cube voxel cluster.
                 Three 36×36 cubes (dirt / grass / stone) drawn inline as SVGPath polygons.
                 No transforms list — coordinates are authored in already-correct screen
                 pixels so the FXML transform-order gotcha doesn't apply. Replaces the
                 previous micaBrandLogo.fxml include which was rendering off-screen due
                 to the transform-order bug in that file. -->
            <HBox alignment="BOTTOM_CENTER" spacing="10.0" GridPane.halignment="CENTER" GridPane.valignment="CENTER">
                <!-- Cube 1: Dirt brown — flat-shaded with darker left/right faces.
                     fx:id is wired by MCLauncherProgressGui to drive the bouncing animation. -->
                <Group fx:id="voxelCube1">
                    <SVGPath fill="#8B6A3F" content="M 18 0 L 36 9 L 18 18 L 0 9 Z"/>
                    <SVGPath fill="#5C4322" content="M 0 9 L 18 18 L 18 36 L 0 27 Z"/>
                    <SVGPath fill="#3F2E14" content="M 36 9 L 18 18 L 18 36 L 36 27 Z"/>
                </Group>
                <!-- Cube 2: Grass green — anchors the cluster center -->
                <Group fx:id="voxelCube2">
                    <SVGPath fill="#6FCF3D" content="M 18 0 L 36 9 L 18 18 L 0 9 Z"/>
                    <SVGPath fill="#3C8527" content="M 0 9 L 18 18 L 18 36 L 0 27 Z"/>
                    <SVGPath fill="#2A6B1E" content="M 36 9 L 18 18 L 18 36 L 36 27 Z"/>
                </Group>
                <!-- Cube 3: Stone gray — completes the dirt/grass/stone block trio -->
                <Group fx:id="voxelCube3">
                    <SVGPath fill="#A8AEB8" content="M 18 0 L 36 9 L 18 18 L 0 9 Z"/>
                    <SVGPath fill="#6B7280" content="M 0 9 L 18 18 L 18 36 L 0 27 Z"/>
                    <SVGPath fill="#4B5563" content="M 36 9 L 18 18 L 18 36 L 36 27 Z"/>
                </Group>
            </HBox>

            <!-- Row 1: Upper label (overall task title) -->
            <Label fx:id="upperLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="420.0"
                   prefWidth="400.0" styleClass="heading-display" text="Just a Moment"
                   textAlignment="CENTER" wrapText="true"
                   GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>

            <!-- Row 2: Section label (current step heading) -->
            <Label fx:id="sectionLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="400.0"
                   prefWidth="390.0" styleClass="muted" text="" textAlignment="CENTER" wrapText="true"
                   GridPane.halignment="CENTER" GridPane.rowIndex="2" GridPane.valignment="CENTER">
                <font>
                    <Font size="13.0" />
                </font>
            </Label>

            <!-- Row 3: Progress bar -->
            <MFXProgressBar fx:id="progressBar" maxWidth="360.0" minWidth="360.0" prefWidth="360.0"
                            progress="0.0" GridPane.halignment="CENTER" GridPane.rowIndex="3"
                            GridPane.valignment="CENTER" />

            <!-- Row 4: Detail label (file-level details below progress bar) -->
            <Label fx:id="detailLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="400.0"
                   prefWidth="390.0" styleClass="subtle" text="" textAlignment="CENTER" wrapText="true"
                   GridPane.halignment="CENTER" GridPane.rowIndex="4" GridPane.valignment="CENTER">
                <font>
                    <Font size="11.0" />
                </font>
            </Label>

            <!-- Row 5: Speed/ETA info below detail label -->
            <Label fx:id="speedLabel" alignment="CENTER" contentDisplay="CENTER" maxWidth="400.0"
                   prefWidth="390.0" styleClass="subtle" text="" textAlignment="CENTER" wrapText="true"
                   GridPane.halignment="CENTER" GridPane.rowIndex="5" GridPane.valignment="CENTER">
                <font>
                    <Font size="10.0" />
                </font>
            </Label>
        </GridPane>
    </GridPane>
</GridPane>
