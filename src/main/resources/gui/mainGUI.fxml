<GridPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="475.0" minWidth="750.0"
          prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane" stylesheets="@../guiStyle-dark.css"
          xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: Announcement banner (conditional, 0-30px) -->
        <RowConstraints fx:id="announcementRow" maxHeight="-Infinity" minHeight="0.0"/>
        <!-- Row 1: Top navigation bar (44px fixed) -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0"/>
        <!-- Row 2: Main content (fills remaining) -->
        <RowConstraints vgrow="ALWAYS"/>
        <!-- Row 3: Bottom status bar (32px fixed) -->
        <RowConstraints maxHeight="32.0" minHeight="32.0" prefHeight="32.0"/>
    </rowConstraints>

    <!-- Row 0: Announcement banner -->
    <Label fx:id="announcement" alignment="CENTER" maxHeight="1.7976931348623157E308"
           maxWidth="1.7976931348623157E308" minHeight="0.0" style="-fx-background-color: #8b0000;"
           text="--" textAlignment="CENTER" wrapText="true"/>

    <!-- Row 1: Compact top navigation bar -->
    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="navBar" GridPane.rowIndex="1">
        <!-- Player identity (compact) -->
        <ImageView fx:id="userImage" accessibleText="Player avatar" fitHeight="28.0" fitWidth="28.0"
                   pickOnBounds="true" preserveRatio="true">
            <HBox.margin><Insets left="4.0"/></HBox.margin>
            <Image url="@../no_user.png"/>
        </ImageView>
        <Label fx:id="playerLabel" text="Player">
            <font><Font size="14.0"/></font>
        </Label>

        <!-- Spacer -->
        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Navigation buttons -->
        <MFXButton fx:id="editButton" text="Edit Packs" prefHeight="28.0"/>
        <MFXButton fx:id="vanillaBtn" text="Vanilla" prefHeight="28.0"/>
        <MFXButton fx:id="settingsBtn" text="Settings" prefHeight="28.0"/>

        <!-- Update icon -->
        <ImageView fx:id="updateImgView" accessibleText="Update available - click to download"
                   focusTraversable="true" fitHeight="24.0" fitWidth="18.0"
                   pickOnBounds="true" preserveRatio="true">
            <Image url="@../update.png"/>
            <HBox.margin><Insets right="4.0"/></HBox.margin>
        </ImageView>
    </HBox>

    <!-- Row 2: Main content (pack list + detail panel) -->
    <HBox GridPane.rowIndex="2">
        <!-- Left: Pack list sidebar -->
        <VBox minWidth="260.0" prefWidth="300.0" maxWidth="340.0" styleClass="stripPane">
            <padding><Insets top="8.0" bottom="8.0" left="8.0" right="8.0"/></padding>
            <ListView fx:id="packSelectionList" fixedCellSize="52" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent;">
                <VBox.margin><Insets top="4.0" bottom="4.0"/></VBox.margin>
            </ListView>
        </VBox>

        <!-- Right: Modpack detail + play panel -->
        <GridPane fx:id="centerPane" HBox.hgrow="ALWAYS" styleClass="centerPane"
                  alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <rowConstraints>
                <!-- Unstable warning (conditional) -->
                <RowConstraints fx:id="unstableWarningRow" fillHeight="false"/>
                <!-- Spacer -->
                <RowConstraints vgrow="ALWAYS"/>
                <!-- Play + Website buttons -->
                <RowConstraints maxHeight="60.0" minHeight="50.0" prefHeight="56.0"/>
                <!-- Spacer below buttons -->
                <RowConstraints vgrow="ALWAYS"/>
            </rowConstraints>
            <padding><Insets bottom="16.0" left="16.0" right="16.0" top="16.0"/></padding>

            <!-- Unstable warning -->
            <Label fx:id="unstableWarning"
                   accessibleText="Warning: This mod pack is marked as unstable (beta). Bugs may be present."
                   alignment="CENTER" maxWidth="400.0" minHeight="0.0" prefHeight="37.0"
                   style="-fx-background-color: #8b0000; -fx-background-radius: 10px;"
                   text="This mod pack is marked as unstable (beta). &#10;Bugs may be present."
                   textAlignment="CENTER" wrapText="true"
                   GridPane.halignment="CENTER">
                <font><Font size="11.0"/></font>
            </Label>

            <!-- Play and Website buttons (centered) -->
            <HBox alignment="CENTER" spacing="16.0" GridPane.rowIndex="2" GridPane.halignment="CENTER">
                <MFXButton fx:id="playBtn" prefHeight="36.0" prefWidth="120.0" text="Play">
                    <font><Font size="14.0"/></font>
                </MFXButton>
                <MFXButton fx:id="websiteBtn" prefHeight="28.0" prefWidth="90.0" text="Website"/>
            </HBox>
        </GridPane>
    </HBox>

    <!-- Row 3: Bottom status bar -->
    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="bottomBar" GridPane.rowIndex="3">
        <Label fx:id="versionLabel" text="Mica Launcher"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="logoutBtn" text="Log Out" prefHeight="22.0"/>
        <MFXButton fx:id="exitBtn" text="Exit" prefHeight="22.0"/>
    </HBox>
</GridPane>
