<GridPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="475.0" minWidth="750.0"
          prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane" stylesheets="@../guiStyle-dark.css"
          xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: Announcement banner (conditional, 0-30px) -->
        <RowConstraints fx:id="announcementRow" maxHeight="-Infinity" minHeight="0.0"/>
        <!-- Row 1: Top navigation bar (44px fixed) -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0"/>
        <!-- Row 2: Main content (fills remaining) -->
        <RowConstraints vgrow="ALWAYS"/>
        <!-- Row 3: Bottom status bar (44px fixed) -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0"/>
    </rowConstraints>

    <!-- Row 0: Announcement banner -->
    <Label fx:id="announcement" alignment="CENTER" maxHeight="1.7976931348623157E308"
           maxWidth="1.7976931348623157E308" minHeight="0.0" styleClass="banner-announcement"
           text="--" textAlignment="CENTER" wrapText="true"/>

    <!-- Row 1: Compact top navigation bar -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="navBar" GridPane.rowIndex="1">
        <!-- Brand lockup: small Mica logo + wordmark -->
        <StackPane>
            <fx:include source="components/micaBrandLogo.fxml"/>
            <StackPane.margin><Insets left="4.0"/></StackPane.margin>
            <scaleX>0.45</scaleX>
            <scaleY>0.45</scaleY>
        </StackPane>
        <Label text="Mica Launcher" styleClass="navBrand"/>

        <!-- Spacer -->
        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Navigation buttons -->
        <MFXButton fx:id="editButton" text="Edit Packs" prefHeight="28.0"/>
        <MFXButton fx:id="vanillaBtn" text="Vanilla" prefHeight="28.0"/>
        <MFXButton fx:id="settingsBtn" text="Settings" prefHeight="28.0"/>

        <!-- Update icon -->
        <ImageView fx:id="updateImgView" accessibleText="Update available - click to download"
                   focusTraversable="true" fitHeight="24.0" fitWidth="18.0"
                   pickOnBounds="true" preserveRatio="true">
            <Image url="@../update.png"/>
        </ImageView>

        <!-- User identity (right-aligned, compact) -->
        <Region styleClass="navDivider" minWidth="1" prefWidth="1" maxWidth="1" prefHeight="22"/>
        <ImageView fx:id="userImage" accessibleText="Player avatar" fitHeight="28.0" fitWidth="28.0"
                   pickOnBounds="true" preserveRatio="true">
            <Image url="@../no_user.png"/>
        </ImageView>
        <Label fx:id="playerLabel" text="Player">
            <HBox.margin><Insets right="4.0"/></HBox.margin>
        </Label>
    </HBox>

    <!-- Row 2: Main content (pack list + hero detail) -->
    <HBox GridPane.rowIndex="2">
        <!-- Left: Pack list sidebar -->
        <VBox minWidth="260.0" prefWidth="300.0" maxWidth="340.0" styleClass="stripPane">
            <padding><Insets top="8.0" bottom="8.0" left="8.0" right="8.0"/></padding>
            <Label text="Library" styleClass="heading-h3 muted">
                <VBox.margin><Insets top="4.0" bottom="6.0" left="6.0"/></VBox.margin>
            </Label>
            <ListView fx:id="packSelectionList" fixedCellSize="56" VBox.vgrow="ALWAYS"
                      style="-fx-background-color: transparent;">
                <VBox.margin><Insets top="2.0" bottom="4.0"/></VBox.margin>
            </ListView>
        </VBox>

        <!-- Right: Modpack hero detail panel -->
        <StackPane fx:id="centerPane" HBox.hgrow="ALWAYS" styleClass="hero-surface">
            <padding><Insets top="24.0" bottom="24.0" left="24.0" right="24.0"/></padding>

            <!-- Hero card: stacked layers — modpack background image, dark gradient overlay, content -->
            <StackPane maxWidth="720" maxHeight="-Infinity" styleClass="heroCardShell">
                <!-- Layer 1: modpack background image (fills card, edges clipped by radius) -->
                <Region fx:id="heroBackgroundLayer" styleClass="heroBackground"/>

                <!-- Layer 2: dark gradient veil — makes text legible regardless of image -->
                <Region styleClass="heroBackgroundVeil"/>

                <!-- Layer 3: foreground content -->
                <VBox alignment="TOP_CENTER" spacing="14" styleClass="heroCard">
                    <padding><Insets top="32.0" bottom="32.0" left="36.0" right="36.0"/></padding>

                    <!-- Pack logo (square, with subtle border) -->
                    <StackPane fx:id="heroPackLogoContainer" minWidth="112" minHeight="112"
                               maxWidth="112" maxHeight="112" styleClass="heroPackLogoContainer">
                        <ImageView fx:id="heroPackLogo" fitWidth="108" fitHeight="108"
                                   preserveRatio="true" pickOnBounds="true"/>
                    </StackPane>

                    <!-- Pack name -->
                    <Label fx:id="heroPackName" text="" alignment="CENTER" textAlignment="CENTER"
                           wrapText="true" styleClass="heading-display heroPackName"/>

                    <!-- Stat chip strip: MC version, Forge version, version, beta flag -->
                    <HBox fx:id="heroChipRow" alignment="CENTER" spacing="8">
                        <Label fx:id="heroChipMc"      styleClass="stat-chip" text="" managed="false" visible="false"/>
                        <Label fx:id="heroChipForge"  styleClass="stat-chip" text="" managed="false" visible="false"/>
                        <Label fx:id="heroChipVersion" styleClass="stat-chip" text="" managed="false" visible="false"/>
                        <Label fx:id="heroChipBeta"   styleClass="stat-chip stat-chip-warn" text="Beta"
                                                      managed="false" visible="false"/>
                    </HBox>

                    <!-- Conditional unstable warning (kept for compatibility) -->
                    <Label fx:id="unstableWarning"
                           accessibleText="Warning: This mod pack is marked as unstable (beta). Bugs may be present."
                           alignment="CENTER" maxWidth="500.0" minHeight="0.0"
                           styleClass="banner-danger"
                           text="This mod pack is marked as unstable (beta). Bugs may be present."
                           textAlignment="CENTER" wrapText="true" managed="false" visible="false">
                        <font><Font size="11.0"/></font>
                    </Label>

                    <!-- Action row: big Play CTA + small Website link -->
                    <HBox alignment="CENTER" spacing="12">
                        <VBox.margin><Insets top="8.0"/></VBox.margin>
                        <MFXButton fx:id="playBtn" text="Play" prefHeight="46.0" prefWidth="200.0"
                                   styleClass="primary playBtn heroPlayBtn">
                            <font><Font size="16.0"/></font>
                        </MFXButton>
                        <MFXButton fx:id="websiteBtn" text="Visit Website" prefHeight="46.0"/>
                    </HBox>
                </VBox>
            </StackPane>
        </StackPane>
    </HBox>

    <!-- Row 3: Bottom status bar (now minimal — version + offline + exit only) -->
    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="bottomBar" GridPane.rowIndex="3">
        <Label fx:id="versionLabel" text="Mica Launcher"/>
        <Label fx:id="offlineLabel" text="Offline Mode" managed="false" visible="false"
               styleClass="chip-offline">
            <font><Font size="11.0"/></font>
        </Label>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="exitBtn" text="Exit" prefHeight="28.0"/>
    </HBox>
</GridPane>
