<GridPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="475.0" minWidth="750.0"
          prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane"
          xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: Top navigation bar (52px, taller for brand lockup) -->
        <RowConstraints maxHeight="52.0" minHeight="52.0" prefHeight="52.0"/>
        <!-- Row 1: Announcement banner (conditional, 0-30px) — sits BELOW the
             navbar so the chrome stays anchored at the top edge and banners
             read as in-app notifications rather than chrome overlays. -->
        <RowConstraints fx:id="announcementRow" maxHeight="-Infinity" minHeight="0.0"/>
        <!-- Row 2: Filter / search row — mirrors the Game Library screen's
             top-bar pattern so the launcher shell feels consistent. Search by
             name, filter by type (modpack vs vanilla), and pick a sort order. -->
        <RowConstraints maxHeight="48.0" minHeight="48.0" prefHeight="48.0"/>
        <!-- Row 3: Pagination bar — prev / page X of Y / next + per-page
             selector. Sits between the filter row and the cards so the user
             can see where they are without scrolling. -->
        <RowConstraints maxHeight="40.0" minHeight="40.0" prefHeight="40.0"/>
        <!-- Row 4: Main content (fills remaining) -->
        <RowConstraints vgrow="ALWAYS"/>
        <!-- Row 5: Bottom status bar -->
        <RowConstraints maxHeight="40.0" minHeight="40.0" prefHeight="40.0"/>
    </rowConstraints>

    <!-- Row 1: Announcement banner (below the navbar) -->
    <Label fx:id="announcement" alignment="CENTER" maxHeight="1.7976931348623157E308"
           maxWidth="1.7976931348623157E308" minHeight="0.0" styleClass="banner-announcement"
           text="--" textAlignment="CENTER" wrapText="true" GridPane.rowIndex="1"/>

    <!-- Row 0: Top navigation bar -->
    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="navBar">
        <padding><Insets left="14.0" right="10.0"/></padding>

        <!-- Brand lockup: pre-scaled SVG Mica logo + wordmark.
             A fixed-size Pane wrapper bounds the layout. JavaFX Group's layoutBounds
             reflect the children's untransformed bounds (1024x1024), regardless of any
             Scale/Translate in its `transforms` list — so dropping the include directly
             into HBox would allocate ~767 px for the logo and push the wordmark to the
             middle of the bar. The Pane gives HBox a deterministic 36x36 box; the
             pre-scaled include renders cleanly inside. -->
        <Pane prefWidth="36.0" prefHeight="36.0" minWidth="36.0" minHeight="36.0"
              maxWidth="36.0" maxHeight="36.0" styleClass="navBrandLogo">
            <fx:include source="components/micaBrandLogo-small.fxml"/>
        </Pane>
        <Label text="Mica Minecraft" styleClass="navBrand"/>

        <!-- Spacer pushes everything else to the right -->
        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Navigation actions. "Library" replaces what used to be two separate buttons
             (Edit Packs + Vanilla) and routes to the combined Game Library screen. -->
        <MFXButton fx:id="libraryBtn" text="Library" prefHeight="28.0"/>
        <MFXButton fx:id="settingsBtn" text="Settings" prefHeight="28.0"/>

        <!-- Update available icon. Inline SVG (download-arrow over a tray bar) instead of
             a PNG file so it's theme-coloured via -fx-fill: -color-primary and never breaks
             when the PNG resource lookup misbehaves. The previous @../update.png include
             intermittently rendered as empty space — replaced wholesale with this vector. -->
        <SVGPath fx:id="updateImgView" accessibleText="Update available - click to download"
                 focusTraversable="true" pickOnBounds="true" styleClass="navUpdateIcon"
                 content="M 9 3 L 13 3 L 13 11 L 17 11 L 11 18 L 5 11 L 9 11 Z M 4 20 L 18 20 L 18 22 L 4 22 Z"/>

        <!-- Help — a Label rather than a Button to avoid MFXButton text-rendering quirks. Click handler
             is wired in the controller; pointer cursor and hover styling come from .helpButton CSS. -->
        <Label fx:id="helpBtn" text="?" styleClass="helpButton"/>

        <!-- Subtle vertical divider between actions and identity -->
        <Region styleClass="navDivider" prefWidth="1" prefHeight="22"/>

        <!-- User identity, right-aligned -->
        <ImageView fx:id="userImage" accessibleText="Player avatar" fitHeight="28.0" fitWidth="28.0"
                   pickOnBounds="true" preserveRatio="true">
            <Image url="@../no_user.png"/>
        </ImageView>
        <Label fx:id="playerLabel" text="Player"/>
    </HBox>

    <!-- Row 2: Filter / search row. Label prefixes (Search / Type / Sort) rather
         than MFX's floatingText so the row stays compact at 48 px. The combo
         boxes default to "All" / "Last Played" so the initial render matches
         the previous behavior (no filter, last-played pack at top). -->
    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="navBar" GridPane.rowIndex="2">
        <padding><Insets left="14.0" right="14.0"/></padding>

        <Label text="Search:" styleClass="muted"/>
        <MFXTextField fx:id="searchField" promptText="Name…" minWidth="180.0" prefWidth="220.0"
                      minHeight="32.0" prefHeight="32.0" maxHeight="32.0"
                      styleClass="no-floating-label"/>

        <Label text="Type:" styleClass="muted"/>
        <MFXComboBox fx:id="typeFilter" minWidth="120.0" prefWidth="130.0"
                     minHeight="32.0" prefHeight="32.0" maxHeight="32.0"/>

        <Label text="Sort:" styleClass="muted"/>
        <MFXComboBox fx:id="sortFilter" minWidth="150.0" prefWidth="170.0"
                     minHeight="32.0" prefHeight="32.0" maxHeight="32.0"/>

        <!-- Optional filter for update-available items. Off by default; flipping it
             on hides packs that are already up to date so the user can focus on
             the ones with new manifest content. Phrased "Recently updated" to
             match the same terminology the Library screen uses on its badges. -->
        <Pane HBox.hgrow="ALWAYS" minWidth="10.0"/>
        <MFXCheckbox fx:id="recentlyUpdatedOnlyCheck" text="Recently updated only"/>
    </HBox>

    <!-- Row 3: Pagination bar — matches the Game Library screen's layout so the
         two screens read as the same shell. Per-page selector lives on the
         right, prev/next + page label in the center. -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="bottomBar" GridPane.rowIndex="3">
        <padding><Insets left="20.0" right="20.0"/></padding>
        <Label fx:id="paginationRangeLabel" text="" styleClass="muted"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="prevPageBtn" prefHeight="28.0" prefWidth="70.0" text="◀ Prev"/>
        <Label fx:id="paginationPageLabel" text="Page 1 of 1" styleClass="muted"/>
        <MFXButton fx:id="nextPageBtn" prefHeight="28.0" prefWidth="70.0" text="Next ▶"/>
        <Pane HBox.hgrow="SOMETIMES" minWidth="20.0"/>
        <Label text="Per page:" styleClass="muted"/>
        <MFXComboBox fx:id="pageSizeFilter" minWidth="80.0" prefWidth="80.0"
                     minHeight="28.0" prefHeight="28.0" maxHeight="28.0"/>
    </HBox>

    <!-- Row 4: Main content — responsive grid of modpack hero cards.
         FlowPane wraps based on available width, so 1, 2, 3, or 4 cards fit per row
         depending on how wide the user makes the window. -->
    <ScrollPane fx:id="modpackScrollPane" GridPane.rowIndex="4"
                fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="modpackScroll">
        <javafx.scene.layout.FlowPane fx:id="modpackCardList" styleClass="modpackCardList"
                                      hgap="20" vgap="20" alignment="TOP_CENTER" prefWrapLength="600">
            <padding><Insets top="24.0" bottom="32.0" left="32.0" right="32.0"/></padding>
            <!-- Cards inserted programmatically by MCLauncherMainGui.populateModpackCards() -->
        </javafx.scene.layout.FlowPane>
    </ScrollPane>

    <!-- Row 5: Bottom status bar -->
    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="bottomBar" GridPane.rowIndex="5">
        <padding><Insets left="14.0" right="14.0"/></padding>
        <Label fx:id="versionLabel" text="Mica Launcher"/>
        <Label fx:id="offlineLabel" text="Offline" managed="false" visible="false" styleClass="chip-offline">
            <font><Font size="11.0"/></font>
        </Label>
        <!-- Background-fetch indicator. Visible while the available-modpacks fetch
             kicked off at startup is still running (see
             GameModPackManager.startAvailableModPacksFetchAsync); hidden as soon as
             that future completes. Lets the main menu render immediately without
             waiting for the available-packs network call, but still signals to the
             user that the Library screen will catch up shortly. -->
        <Label fx:id="backgroundFetchLabel" text="Loading available packs…"
               managed="false" visible="false" styleClass="muted">
            <font><Font size="11.0"/></font>
        </Label>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="exitBtn" text="Exit" prefHeight="26.0"/>
    </HBox>
</GridPane>
