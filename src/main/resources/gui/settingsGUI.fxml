<GridPane fx:id="rootPane" minHeight="475.0" minWidth="750.0" prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: top navbar — matches main-menu + library pattern (~52 px) -->
        <RowConstraints maxHeight="52.0" minHeight="52.0" prefHeight="52.0" />
        <!-- Row 1: announcement banner (conditional 0/30 px) — sits below the navbar -->
        <RowConstraints fx:id="announcementRow" maxHeight="-Infinity" minHeight="0.0" />
        <!-- Row 2: sidebar + content -->
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <!-- Row 3: bottom bar (Save / Return), ~44 px -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0" />
    </rowConstraints>

    <!-- Row 1: Announcement banner (below the navbar) -->
    <Label fx:id="announcement" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" styleClass="banner-announcement" text="--" wrapText="true" GridPane.rowIndex="1" />

    <!-- Row 0: Top navbar — mirrors mainGUI / library navbars so the Settings screen
         reads as part of the same app shell rather than a one-off layout. Brand
         lockup on the left (matching main menu), screen title next to it, then the
         help button on the right. Save + Return stay on the bottom action bar so
         they're easy to reach without scrolling. -->
    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="navBar">
        <padding><Insets left="14.0" right="10.0"/></padding>

        <Pane prefWidth="36.0" prefHeight="36.0" minWidth="36.0" minHeight="36.0"
              maxWidth="36.0" maxHeight="36.0" styleClass="navBrandLogo">
            <fx:include source="components/micaBrandLogo-small.fxml"/>
        </Pane>
        <Label text="Settings" styleClass="heading-h2"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <Label fx:id="helpBtn" text="?" styleClass="helpButton"/>
    </HBox>

    <!-- Row 2: Sidebar + Content -->
    <HBox GridPane.rowIndex="2" HBox.hgrow="ALWAYS">
        <!-- Left sidebar navigation -->
        <VBox minWidth="180.0" maxWidth="180.0" prefWidth="180.0" styleClass="stripPane" spacing="2">
            <padding>
                <Insets top="8.0" bottom="8.0" left="4.0" right="4.0" />
            </padding>
            <MFXButton fx:id="navAccount" text="Account" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navGame" text="Game" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navAppearance" text="Appearance" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navAdvanced" text="Advanced" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navNetwork" text="Network" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navSecurity" text="Security" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navSystem" text="System" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navDiscord" text="Discord" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <!-- About pinned to the bottom of the sidebar via a flex spacer — it's
                 a destination users rarely visit, so we get it out of the primary
                 settings rhythm without hiding it entirely. -->
            <Pane VBox.vgrow="ALWAYS" />
            <MFXButton fx:id="navAbout" text="About" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
        </VBox>

        <!-- Right content area: stacked category panes -->
        <StackPane fx:id="settingsContent" HBox.hgrow="ALWAYS">

            <!-- Category 0: Account -->
            <ScrollPane fx:id="accountPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="Account" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <!-- Player profile card -->
                    <VBox styleClass="settingsContainer" spacing="12">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <ImageView fx:id="accountAvatar" fitHeight="64.0" fitWidth="64.0" pickOnBounds="true" preserveRatio="true" />
                            <VBox spacing="4">
                                <Label fx:id="accountNameLabel" text="Player">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <Label fx:id="accountUuidLabel" text="UUID: ..." wrapText="true">
                                    <font>
                                        <Font size="11.0" />
                                    </font>
                                </Label>
                            </VBox>
                        </HBox>
                    </VBox>
                    <!-- Helpful links -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Helpful Links">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="minecraftNetBtn" prefHeight="30.0" text="Minecraft.net">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="msAccountBtn" prefHeight="30.0" text="Microsoft Account">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                    </VBox>
                    <!-- Log out -->
                    <VBox styleClass="settingsContainer, dangerZone" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Sign Out">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="Signing out will clear your saved login and restart the launcher." wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXButton fx:id="logoutBtn" prefHeight="30.0" prefWidth="120.0" text="Log Out" styleClass="dangerZone">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </MFXButton>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 1: Game -->
            <ScrollPane fx:id="gamePane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="Game" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Minimum RAM (GB)" />
                        <Spinner fx:id="minRamGb" editable="true" prefWidth="120.0" />
                        <Label text="Maximum RAM (GB)" />
                        <Spinner fx:id="maxRamGb" editable="true" prefWidth="120.0" />
                        <Label fx:id="sysRamLabel" text="You have X GB RAM. You're currently using X GB." wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="JVM Preset" />
                        <MFXComboBox fx:id="jvmPresetSelection" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="250.0" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 1: Appearance -->
            <ScrollPane fx:id="appearancePane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="Appearance" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Theme" />
                        <MFXComboBox fx:id="themeSelection" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="250.0" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 2: Advanced -->
            <ScrollPane fx:id="advancedPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="Advanced" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <MFXToggleButton fx:id="debugCheckBox" text="Debug Mode" />
                        <MFXToggleButton fx:id="windowResizeCheckBox" text="Window Resizing" />
                        <MFXToggleButton fx:id="enhancedLoggingCheckBox" text="Enhanced Logging" />
                        <MFXToggleButton fx:id="inGameConsoleCheckBox" text="In-Game Console" />
                        <MFXToggleButton fx:id="batteryThrottleCheckBox" text="Throttle Downloads on Battery" />
                        <MFXToggleButton fx:id="lwjglArmPatchCheckBox" text="LWJGL ARM64 Patching" />
                        <Label styleClass="muted" text="Replaces x86_64 LWJGL2 natives with ARM64 builds for Minecraft 1.12.2 and below on Apple Silicon / ARM Linux." wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 3: Network -->
            <ScrollPane fx:id="networkPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="Network" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <MFXToggleButton fx:id="proxyEnableCheckBox" text="Enable Proxy" />
                        <Label text="Proxy Type" />
                        <MFXComboBox fx:id="proxyTypeSelection" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="120.0" />
                        <Label text="Proxy Host" />
                        <TextField fx:id="proxyHostField" promptText="Proxy Host (e.g. 127.0.0.1)" prefWidth="250.0" />
                        <Label text="Proxy Port" />
                        <Spinner fx:id="proxyPortSpinner" editable="true" prefWidth="120.0" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 4: Security -->
            <ScrollPane fx:id="securityPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="Security" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Malware Scanning">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label fx:id="scanFolderLabel" text="Scan Folder: /path" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="scanBtn" prefHeight="30.0" prefWidth="110.0" text="Scan">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="scanFolderBtn" prefHeight="30.0" prefWidth="110.0" text="Change Folder">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXProgressBar fx:id="scanProgressBar" />
                        </HBox>
                        <Label fx:id="scanOutputLabel" text="Scan Output" wrapText="true" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 5: System -->
            <ScrollPane fx:id="systemPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="System" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Reset &amp; Runtime Options">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="resetLauncherBtn" prefHeight="30.0" prefWidth="120.0" text="Reset Launcher">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="resetRuntimeBtn" prefHeight="30.0" prefWidth="120.0" text="Reset Runtimes">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                        <MFXButton fx:id="manageRuntimeBtn" prefHeight="30.0" prefWidth="140.0" text="Manage Runtimes">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </MFXButton>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Import / Export">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="exportSettingsBtn" prefHeight="30.0" prefWidth="120.0" text="Export Settings">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="importSettingsBtn" prefHeight="30.0" prefWidth="120.0" text="Import Settings">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <MFXButton fx:id="openFolderBtn" prefHeight="28.0" prefWidth="180.0" text="Open Launcher Folder" />
                        <Label fx:id="versionLabel" text="Launcher Version: ERR_UNK" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 7: Discord -->
            <ScrollPane fx:id="discordPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="Discord" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Rich presence toggle (moved here from Advanced for grouping). -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Rich Presence">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="discordCheckBox" text="Discord Integration" />
                        <Label styleClass="muted" text="Show what you're playing on your Discord profile. Requires the Discord desktop app to be running on the same machine — the launcher talks to it locally via IPC, no token or login required." wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>

                    <!-- "Join Game" invite toggle — Discord-specific party + joinSecret on
                         the in-game presence so friends see a "Join Game" button. -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="Friend Invites">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="discordInvitesCheckBox" text="Allow Discord Invites" />
                        <Label styleClass="muted" text="When enabled, friends who see your Discord status while you're in-game get a &quot;Join Game&quot; button on your profile that auto-installs and launches the same modpack on their machine. Disables only the join button — the rich presence itself is controlled by the toggle above." wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <Label styleClass="muted" text="You can also right-click any modpack card on the main menu and pick &quot;Copy Discord Invite Link&quot; to share the join URL directly in any chat." wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 8: About / Attributions -->
            <ScrollPane fx:id="aboutPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="About" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Launcher identity card -->
                    <VBox styleClass="settingsContainer" spacing="6">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <Label fx:id="aboutAppNameLabel" text="Mica Minecraft Launcher">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="aboutVersionLabel" text="Version ..." wrapText="true">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <Label text="© 2021–2026 Mica Technologies" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <!-- Update-check toggle. Lives in the launcher identity card
                             since it's directly tied to the version info above —
                             a user noticing they're on an old version naturally
                             looks here for "how do I get updates." Default ON so
                             new installs receive update prompts. -->
                        <MFXToggleButton fx:id="launcherUpdateCheckBox" text="Check for launcher updates"/>
                        <Label styleClass="muted" text="When off, the launcher won't reach out on startup or show the update-available icon in the navbar." wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <MFXButton fx:id="aboutWebsiteBtn" prefHeight="28.0" prefWidth="140.0" text="Visit Website">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="aboutSourceBtn" prefHeight="28.0" prefWidth="140.0" text="View Source">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                    </VBox>

                    <!-- Trademark + non-affiliation notice -->
                    <VBox styleClass="settingsContainer" spacing="6">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <Label text="Minecraft Trademark">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
