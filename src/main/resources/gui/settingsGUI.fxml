<GridPane fx:id="rootPane" minHeight="475.0" minWidth="750.0" prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: top navbar — matches main-menu + library pattern (~52 px) -->
        <RowConstraints maxHeight="52.0" minHeight="52.0" prefHeight="52.0" />
        <!-- Row 1: announcement banner (conditional 0/30 px) — sits below the navbar -->
        <RowConstraints fx:id="announcementRow" maxHeight="-Infinity" minHeight="0.0" />
        <!-- Row 2: sidebar + content -->
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <!-- Row 3: bottom bar (Save / Return), ~44 px -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0" />
    </rowConstraints>

    <!-- Row 1: Announcement banner (below the navbar) -->
    <Label fx:id="announcement" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" styleClass="banner-announcement" text="--" wrapText="true" GridPane.rowIndex="1" />

    <!-- Row 0: Top navbar — mirrors mainGUI / library navbars so the Settings screen
         reads as part of the same app shell rather than a one-off layout. Brand
         lockup on the left (matching main menu), screen title next to it, then the
         help button on the right. Save + Return stay on the bottom action bar so
         they're easy to reach without scrolling. -->
    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="navBar">
        <padding><Insets left="14.0" right="10.0"/></padding>

        <Pane prefWidth="36.0" prefHeight="36.0" minWidth="36.0" minHeight="36.0"
              maxWidth="36.0" maxHeight="36.0" styleClass="navBrandLogo">
            <fx:include source="components/micaBrandLogo-small.fxml"/>
        </Pane>
        <Label text="%settings.fxml.settings" styleClass="navBrand"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <Label fx:id="offlineLabel" text="%settings.fxml.offline" managed="false" visible="false"
               styleClass="chip-offline"/>
        <Label fx:id="helpBtn" text="?" styleClass="helpButton"/>
    </HBox>

    <!-- Row 2: Sidebar + Content -->
    <HBox GridPane.rowIndex="2" HBox.hgrow="ALWAYS">
        <!-- Left sidebar navigation -->
        <VBox minWidth="180.0" maxWidth="180.0" prefWidth="180.0" styleClass="stripPane" spacing="2">
            <padding>
                <Insets top="8.0" bottom="8.0" left="4.0" right="4.0" />
            </padding>
            <MFXButton fx:id="navAccount" text="%settings.fxml.account" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navGame" text="%settings.fxml.game" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navAppearance" text="%settings.fxml.appearance" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navAdvanced" text="%settings.fxml.advanced" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navNetwork" text="%settings.fxml.network" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navSecurity" text="%settings.fxml.security" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navSystem" text="%settings.fxml.system" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navDiscord" text="%settings.fxml.discord" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <MFXButton fx:id="navRgb" text="%settings.fxml.rgb" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
            <!-- About pinned to the bottom of the sidebar via a flex spacer — it's
                 a destination users rarely visit, so we get it out of the primary
                 settings rhythm without hiding it entirely. -->
            <Pane VBox.vgrow="ALWAYS" />
            <MFXButton fx:id="navAbout" text="%settings.fxml.about" styleClass="settingsNavBtn" maxWidth="1.7976931348623157E308" minHeight="36.0" prefHeight="36.0" />
        </VBox>

        <!-- Right content area: stacked category panes -->
        <StackPane fx:id="settingsContent" HBox.hgrow="ALWAYS">

            <!-- Category 0: Account -->
            <ScrollPane fx:id="accountPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.account" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <!-- Player profile card -->
                    <VBox styleClass="settingsContainer" spacing="12">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <ImageView fx:id="accountAvatar" fitHeight="64.0" fitWidth="64.0" pickOnBounds="true" preserveRatio="true" />
                            <VBox spacing="4">
                                <Label fx:id="accountNameLabel" text="%settings.fxml.player">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <Label fx:id="accountUuidLabel" text="%settings.fxml.uuid" wrapText="true">
                                    <font>
                                        <Font size="11.0" />
                                    </font>
                                </Label>
                            </VBox>
                        </HBox>
                    </VBox>
                    <!-- Helpful links -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.helpfulLinks">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="minecraftNetBtn" prefHeight="30.0" text="%settings.fxml.minecraftNet">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="msAccountBtn" prefHeight="30.0" text="%settings.fxml.microsoftAccount">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                    </VBox>
                    <!-- Saved Accounts — populated by setupAccountTab() from
                         the ProfileArchive list. Rows are appended at runtime
                         to the savedAccountsList VBox; the FXML just declares
                         the container chrome. -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.savedAccounts">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.savedAccountsHint" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <VBox fx:id="savedAccountsList" spacing="6" />
                        <MFXButton fx:id="addAccountBtn" prefHeight="30.0" prefWidth="180.0" text="%settings.fxml.addAccount">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </MFXButton>
                    </VBox>
                    <!-- Log out -->
                    <VBox styleClass="settingsContainer, dangerZone" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.signOut">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.signingOutWill" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXButton fx:id="logoutBtn" prefHeight="30.0" prefWidth="120.0" text="%settings.fxml.logOut" styleClass="dangerZone">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </MFXButton>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 1: Game -->
            <ScrollPane fx:id="gamePane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.game" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.minimumRamGb" />
                        <Spinner fx:id="minRamGb" editable="true" prefWidth="120.0" />
                        <Label text="%settings.fxml.maximumRamGb" />
                        <Spinner fx:id="maxRamGb" editable="true" prefWidth="120.0" />
                        <Label fx:id="sysRamLabel" text="%settings.fxml.youHaveX" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.jvmPreset" />
                        <MFXComboBox fx:id="jvmPresetSelection" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="250.0" />
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <MFXButton fx:id="generateJvmArgsBtn" text="%settings.fxml.generateJvmArgs" prefHeight="32.0" />
                            <Label fx:id="generateJvmArgsHint" text="" styleClass="muted" wrapText="true">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </Label>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 1: Appearance -->
            <ScrollPane fx:id="appearancePane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.appearance" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.theme" />
                        <MFXComboBox fx:id="themeSelection" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="250.0" />
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.language">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.defaultsToYour" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXComboBox fx:id="languageSelection" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="300.0" />
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.packImagery">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.whenOnModpack" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="showPackBackgroundsToggle" text="%settings.fxml.showPackBackground" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 2: Advanced -->
            <ScrollPane fx:id="advancedPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.advanced" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <MFXToggleButton fx:id="debugCheckBox" text="%settings.fxml.debugMode" />
                        <MFXToggleButton fx:id="windowResizeCheckBox" text="%settings.fxml.windowResizing" />
                        <MFXToggleButton fx:id="enhancedLoggingCheckBox" text="%settings.fxml.enhancedLogging" />
                        <MFXToggleButton fx:id="inGameConsoleCheckBox" text="%settings.fxml.inGameConsole" />
                        <MFXToggleButton fx:id="batteryThrottleCheckBox" text="%settings.fxml.throttleDownloadsOn" />
                        <MFXToggleButton fx:id="lwjglArmPatchCheckBox" text="%settings.fxml.lwjglArm64Patching" />
                        <Label styleClass="muted" text="%settings.fxml.replacesX86_64Lwjgl2" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.securityScanFrequency">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.howOftenThe" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXComboBox fx:id="defaultScanFrequencyCombo" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="280.0" />
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.backupHeader">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.backupBlurb" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="autoBackupToggle" text="%settings.fxml.autoBackupBeforeUpdate" />
                        <MFXToggleButton fx:id="backupIncludeSavesToggle" text="%settings.fxml.backupIncludeSaves" />
                        <Label text="%settings.fxml.backupIncludeSavesHint" wrapText="true" styleClass="muted">
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Label>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="%settings.fxml.backupMaxCount" />
                            <Spinner fx:id="backupMaxCountSpinner" editable="true" prefWidth="80.0" />
                            <Label text="%settings.fxml.backupMaxAgeDays" />
                            <Spinner fx:id="backupMaxAgeDaysSpinner" editable="true" prefWidth="80.0" />
                        </HBox>
                        <Label text="%settings.fxml.backupCountAgeHint" wrapText="true" styleClass="muted">
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Label>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.gameFileIntegrity">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.reHashesEvery" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="verifyAllGameFilesBtn" prefHeight="30.0" prefWidth="180.0" text="%settings.fxml.verifyAllGame">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.thirdPartyIntegrations">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.curseforgeCoreApi" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <MFXPasswordField fx:id="curseForgeApiKeyField" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="320.0" floatingText="CurseForge API key" />
                            <MFXButton fx:id="curseForgeApiKeySaveBtn" prefHeight="30.0" prefWidth="80.0" text="%settings.fxml.save">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="curseForgeApiKeyClearBtn" prefHeight="30.0" prefWidth="80.0" text="%settings.fxml.clear">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                        <Label fx:id="curseForgeApiKeyStatusLabel" styleClass="muted">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 3: Network -->
            <ScrollPane fx:id="networkPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.network" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <MFXToggleButton fx:id="proxyEnableCheckBox" text="%settings.fxml.enableProxy" />
                        <Label text="%settings.fxml.proxyType" />
                        <MFXComboBox fx:id="proxyTypeSelection" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="120.0" />
                        <Label text="%settings.fxml.proxyHost" />
                        <TextField fx:id="proxyHostField" promptText="Proxy Host (e.g. 127.0.0.1)" prefWidth="250.0" />
                        <Label text="%settings.fxml.proxyPort" />
                        <Spinner fx:id="proxyPortSpinner" editable="true" prefWidth="120.0" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 4: Security -->
            <ScrollPane fx:id="securityPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.security" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.malwareScanning">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label fx:id="scanFolderLabel" text="%settings.fxml.scanFolderPath" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="scanBtn" prefHeight="30.0" prefWidth="110.0" text="%settings.fxml.scan">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="scanFolderBtn" prefHeight="30.0" prefWidth="110.0" text="%settings.fxml.changeFolder">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXProgressBar fx:id="scanProgressBar" />
                        </HBox>
                        <Label fx:id="scanOutputLabel" text="%settings.fxml.scanOutput" wrapText="true" />
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.deepLinksMmcl">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.whenEnabledQuot" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="uriHandlerToggle" text="%settings.fxml.allowMmclDeep" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 5: System -->
            <ScrollPane fx:id="systemPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.system" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.resetAmpRuntime">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="resetLauncherBtn" prefHeight="30.0" prefWidth="120.0" text="%settings.fxml.resetLauncher">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="resetRuntimeBtn" prefHeight="30.0" prefWidth="120.0" text="%settings.fxml.resetRuntimes">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                        <MFXButton fx:id="manageRuntimeBtn" prefHeight="30.0" prefWidth="140.0" text="%settings.fxml.manageRuntimes">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </MFXButton>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.importExport">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <HBox spacing="8">
                            <MFXButton fx:id="exportSettingsBtn" prefHeight="30.0" prefWidth="120.0" text="%settings.fxml.exportSettings">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="importSettingsBtn" prefHeight="30.0" prefWidth="120.0" text="%settings.fxml.importSettings">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                    </VBox>
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <MFXButton fx:id="openFolderBtn" prefHeight="28.0" prefWidth="180.0" text="%settings.fxml.openLauncherFolder" />
                        <Label fx:id="versionLabel" text="%settings.fxml.launcherVersionErr_unk" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 7: Discord -->
            <ScrollPane fx:id="discordPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.discord" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Rich presence toggle (moved here from Advanced for grouping). -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.richPresence">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="discordCheckBox" text="%settings.fxml.discordIntegration" />
                        <Label styleClass="muted" text="%settings.fxml.showWhatYou" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>

                    <!-- "Join Game" invite toggle — Discord-specific party + joinSecret on
                         the in-game presence so friends see a "Join Game" button. -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.friendInvites">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="discordInvitesCheckBox" text="%settings.fxml.allowDiscordInvites" />
                        <Label styleClass="muted" text="%settings.fxml.whenEnabledFriends" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <Label styleClass="muted" text="%settings.fxml.youCanAlso" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 8: RGB Integration -->
            <ScrollPane fx:id="rgbPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.rgbLighting" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Master enable + backend choice + live status. -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.lightingBackend">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="rgbEnableToggle" text="%settings.fxml.enableRgbLighting" />
                        <Label styleClass="muted" text="%settings.fxml.whenEnabledThe" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="%settings.fxml.backend" />
                            <MFXComboBox fx:id="rgbBackendCombo" prefWidth="200.0" />
                            <Label fx:id="rgbStatusChip" text="%settings.fxml.disabled" styleClass="stat-chip" />
                        </HBox>
                        <Label styleClass="muted" text="%settings.fxml.autoRunsEvery" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>

                        <Label fx:id="rgbAutoToggleHeader" text="%settings.fxml.autoModeIntegrations" styleClass="muted">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <VBox fx:id="rgbAutoToggleBox" spacing="4">
                            <MFXToggleButton fx:id="rgbEnableOpenRgbToggle" text="%settings.fxml.openrgb" />
                            <MFXToggleButton fx:id="rgbEnableChromaNativeToggle" text="%settings.fxml.razerChromaNative" />
                            <MFXToggleButton fx:id="rgbEnableWindowsDlToggle" text="%settings.fxml.windowsDynamicLighting" />
                            <MFXToggleButton fx:id="rgbEnableCorsairToggle" text="%settings.fxml.corsairIcue" />
                            <MFXToggleButton fx:id="rgbEnableAsusAuraToggle" text="%settings.fxml.asusAuraLegacy" />
                            <MFXToggleButton fx:id="rgbEnableChromaRestToggle" text="%settings.fxml.razerChromaRest" />
                        </VBox>
                        <Label styleClass="muted" text="%settings.fxml.turnOffThe" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>

                    <!-- Idle/menu effect toggle + animation style picker. -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.menuEffect">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="rgbMenuEffectToggle" text="%settings.fxml.lightUpDevices" />
                        <Label styleClass="muted" text="%settings.fxml.whenOnYour" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.animationStyle" styleClass="muted">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXComboBox fx:id="rgbEffectStyleSelection" maxHeight="36.0" minHeight="36.0" prefHeight="36.0" prefWidth="220.0" />
                        <Label styleClass="muted" text="%settings.fxml.solidSingleSteady" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>

                    <!-- Effect behavior toggles. -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.inGameEffects">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="rgbUsePackColorsToggle" text="%settings.fxml.useModpackColors" />
                        <Label styleClass="muted" text="%settings.fxml.lightUpThe" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXToggleButton fx:id="rgbHighlightKeysToggle" text="%settings.fxml.highlightMinecraftKeys" />
                        <Label styleClass="muted" text="%settings.fxml.overlayWasdE" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>

                    <!-- Test button — flashes solid magenta on every connected device so the user
                         can confirm the backend is talking to their hardware. -->
                    <VBox styleClass="settingsContainer" spacing="8">
                        <padding>
                            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                        </padding>
                        <Label text="%settings.fxml.test">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label styleClass="muted" text="%settings.fxml.flashesSolidMagenta" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <MFXButton fx:id="rgbTestBtn" prefHeight="30.0" prefWidth="160.0" text="%settings.fxml.testConnection" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- Category 9: About / Attributions -->
            <ScrollPane fx:id="aboutPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-width: 0;" visible="false" managed="false">
                <VBox spacing="12" fillWidth="true">
                    <padding>
                        <Insets top="16.0" bottom="16.0" left="16.0" right="16.0" />
                    </padding>
                    <Label text="%settings.fxml.about" styleClass="settingsCategoryHeader">
                        <font>
                            <Font name="System Bold" size="18.0" />
                        </font>
                    </Label>

                    <!-- Launcher identity card -->
                    <VBox styleClass="settingsContainer" spacing="6">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <Label fx:id="aboutAppNameLabel" text="%settings.fxml.micaMinecraftLauncher">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Label fx:id="aboutVersionLabel" text="%settings.fxml.version" wrapText="true">
                            <font>
                                <Font size="12.0" />
                            </font>
                        </Label>
                        <Label text="© 2021–2026 Mica Technologies" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <!-- Update-check toggle. Lives in the launcher identity card
                             since it's directly tied to the version info above —
                             a user noticing they're on an old version naturally
                             looks here for "how do I get updates." Default ON so
                             new installs receive update prompts. -->
                        <MFXToggleButton fx:id="launcherUpdateCheckBox" text="%settings.fxml.checkForLauncher"/>
                        <Label styleClass="muted" text="%settings.fxml.whenOffThe" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <MFXButton fx:id="aboutWebsiteBtn" prefHeight="28.0" prefWidth="140.0" text="%settings.fxml.visitWebsite">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                            <MFXButton fx:id="aboutSourceBtn" prefHeight="28.0" prefWidth="140.0" text="%settings.fxml.viewSource">
                                <font>
                                    <Font size="11.0" />
                                </font>
                            </MFXButton>
                        </HBox>
                    </VBox>

                    <!-- Trademark + non-affiliation notice -->
                    <VBox styleClass="settingsContainer" spacing="6">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <Label text="%settings.fxml.minecraftTrademark">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.minecraftIsA" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>

                    <!-- Open-source acknowledgments -->
                    <VBox styleClass="settingsContainer" spacing="6">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <Label text="%settings.fxml.openSourceAcknowledgments">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.theLauncherUses" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <Label text="• OpenJFX — GPLv2 with Classpath Exception&#10;• MaterialFX (palexdev) — LGPL 3.0&#10;• jthemedetecor (Dansoftowner) — Apache 2.0&#10;• FXTaskbarProgressBar (Dansoftowner) — Apache 2.0&#10;• oshi-core — MIT&#10;• JNA / JNA Platform — Apache 2.0 / LGPL 2.1&#10;• Google Gson — Apache 2.0&#10;• Apache Commons IO — Apache 2.0&#10;• Apache Commons Lang3 — Apache 2.0&#10;• SLF4J — MIT&#10;• jarchivelib — Apache 2.0&#10;• minecraft_authenticator — MIT&#10;• jarscanner — MIT" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.fullLicenseTexts" wrapText="true">
                            <font>
                                <Font size="10.0" />
                            </font>
                        </Label>
                    </VBox>

                    <!-- Runtime dependencies — Java distributions pulled at run time,
                         distinct from the bundled libraries above. -->
                    <VBox styleClass="settingsContainer" spacing="6">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <Label text="%settings.fxml.javaRuntimes">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.modernMinecraftVersions" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>

                    <!-- ARM64 native library credits — community-built binaries the
                         launcher downloads on demand when LWJGL ARM Patching is enabled. -->
                    <VBox styleClass="settingsContainer" spacing="6">
                        <padding>
                            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                        </padding>
                        <Label text="%settings.fxml.arm64NativeLibraries">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                        <Label text="%settings.fxml.whenLwjglArm" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                        <Label text="• MinecraftMachina/lwjgl — LWJGL2 ARM64 macOS natives (BSD)&#10;• r58Playz/jinput-m1 — jinput ARM64 macOS natives&#10;• theofficialgman/lwjgl3-binaries-arm64 — LWJGL2 / jinput ARM64 Linux natives" wrapText="true">
                            <font>
                                <Font size="11.0" />
                            </font>
                        </Label>
                    </VBox>
                </VBox>
            </ScrollPane>

        </StackPane>
    </HBox>

    <!-- Row 3: Bottom bar with Save + Return — right-aligned via a flex spacer
         to match the modpack editor / runtime / library / main-menu pattern. -->
    <HBox styleClass="bottomBar" alignment="CENTER_LEFT" spacing="10.0" minHeight="44.0" maxHeight="44.0" prefHeight="44.0" GridPane.rowIndex="3">
        <padding>
            <Insets left="14.0" right="14.0" />
        </padding>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="saveBtn" prefHeight="28.0" prefWidth="80.0" text="%settings.fxml.save" />
        <MFXButton fx:id="returnBtn" prefHeight="28.0" prefWidth="80.0" text="%settings.fxml.return" />
    </HBox>
</GridPane>
