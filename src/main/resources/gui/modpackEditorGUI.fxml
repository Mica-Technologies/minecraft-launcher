<GridPane fx:id="rootPane" minHeight="475.0" minWidth="750.0"
          prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane"
          xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: top navbar (brand + title + help), ~52 px to match mainGUI -->
        <RowConstraints maxHeight="52.0" minHeight="52.0" prefHeight="52.0"/>
        <!-- Row 1: announcement banner (conditional, 0-60 px) — below the navbar -->
        <RowConstraints fx:id="announcementRow" maxHeight="-Infinity" minHeight="0.0"/>
        <!-- Row 2: file/document toolbar (New / Open / Validate / Diff) -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0"/>
        <!-- Row 3: TabPane fills remaining space -->
        <RowConstraints vgrow="ALWAYS"/>
        <!-- Row 4: bottom action bar (status + Save + Return), ~44 px -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0"/>
    </rowConstraints>

    <!-- Row 1: Announcement (below the navbar) -->
    <Label fx:id="announcement" alignment="CENTER" maxHeight="1.7976931348623157E308"
           maxWidth="1.7976931348623157E308" minHeight="0.0" styleClass="banner-announcement"
           text="--" wrapText="true" GridPane.rowIndex="1"/>

    <!-- Row 0: Top navbar — matches mainGUI / library / settings so the editor
         reads as part of the same app shell. Brand lockup on the left, screen
         title alongside, help button on the right. File-operation tools live
         in the sub-toolbar below; document state (Save/Return) lives in the
         bottom action bar. -->
    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="navBar">
        <padding><Insets left="14.0" right="10.0"/></padding>

        <Pane prefWidth="36.0" prefHeight="36.0" minWidth="36.0" minHeight="36.0"
              maxWidth="36.0" maxHeight="36.0" styleClass="navBrandLogo">
            <fx:include source="components/micaBrandLogo-small.fxml"/>
        </Pane>
        <Label text="Modpack Editor" styleClass="navBrand"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <Label fx:id="offlineLabel" text="Offline" managed="false" visible="false"
               styleClass="chip-offline"/>
        <Label fx:id="helpBtn" text="?" styleClass="helpButton"/>
    </HBox>

    <!-- Row 2: File / document tools. These are contextual to the editor
         (load a manifest, validate it, diff against a reference) so they live
         immediately below the navbar instead of cluttering it. -->
    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="stripPane" GridPane.rowIndex="2">
        <padding>
            <Insets bottom="6.0" left="16.0" right="16.0" top="6.0"/>
        </padding>
        <MFXButton fx:id="newBtn" prefHeight="28.0" text="New"/>
        <MFXButton fx:id="openFileBtn" prefHeight="28.0" text="Open File"/>
        <MFXButton fx:id="openUrlBtn" prefHeight="28.0" text="Open URL"/>
        <Pane HBox.hgrow="SOMETIMES" minWidth="16.0"/>
        <MFXButton fx:id="validateBtn" prefHeight="28.0" text="Validate"/>
        <MFXButton fx:id="diffBtn" prefHeight="28.0" text="Diff"/>
    </HBox>

    <!-- Row 3: TabPane -->
    <TabPane fx:id="editorTabPane" tabClosingPolicy="UNAVAILABLE" GridPane.rowIndex="3">
        <Tab text="Metadata" closable="false">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                <VBox fx:id="metadataVBox" spacing="12.0" style="-fx-background-color: transparent;">
                    <padding>
                        <Insets bottom="16.0" left="24.0" right="24.0" top="16.0"/>
                    </padding>

                    <!-- Pack Identity -->
                    <Label text="Pack Identity" style="-fx-font-weight: bold;">
                        <font><Font size="14.0"/></font>
                    </Label>
                    <MFXTextField fx:id="packNameField" floatingText="Pack Name" maxWidth="500.0"
                                  prefWidth="500.0" minHeight="48.0" prefHeight="48.0"/>
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <MFXTextField fx:id="packVersionField" floatingText="Pack Version" maxWidth="300.0"
                                      prefWidth="300.0" minHeight="48.0" prefHeight="48.0"/>
                        <MFXButton fx:id="bumpMajorBtn" text="Major" prefHeight="28.0"/>
                        <MFXButton fx:id="bumpMinorBtn" text="Minor" prefHeight="28.0"/>
                        <MFXButton fx:id="bumpPatchBtn" text="Patch" prefHeight="28.0"/>
                    </HBox>
                    <MFXTextField fx:id="packURLField" floatingText="Pack Website URL" maxWidth="500.0"
                                  prefWidth="500.0" minHeight="48.0" prefHeight="48.0"/>
                    <MFXTextField fx:id="packMinRAMField" floatingText="Minimum RAM (GB)" maxWidth="500.0"
                                  prefWidth="500.0" minHeight="48.0" prefHeight="48.0"/>

                    <!-- Flags -->
                    <Label text="Flags" style="-fx-font-weight: bold;">
                        <padding><Insets top="8.0"/></padding>
                        <font><Font size="14.0"/></font>
                    </Label>
                    <MFXToggleButton fx:id="packUnstableToggle" text="Unstable (Beta)"/>
                    <MFXToggleButton fx:id="packCustomDiscordRpcToggle" text="Custom Discord RPC"/>

                    <!-- Modloader -->
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <Label text="Modloader" style="-fx-font-weight: bold;">
                            <font><Font size="14.0"/></font>
                        </Label>
                        <MFXComboBox fx:id="packModLoaderTypeCombo" prefWidth="160.0" minHeight="32.0"/>
                        <MFXButton fx:id="forgePickerBtn" text="Pick Forge Version" prefHeight="28.0"/>
                    </HBox>
                    <Label fx:id="packModLoaderHint" styleClass="muted" wrapText="true"
                           text="Forge / NeoForge: paste the installer JAR URL. Fabric: paste the meta.fabricmc.net profile-JSON URL (hash optional)."/>
                    <MFXTextField fx:id="packForgeURLField" floatingText="Modloader URL (installer JAR or Fabric profile JSON)" maxWidth="500.0"
                                  prefWidth="500.0" minHeight="48.0" prefHeight="48.0"/>
                    <MFXTextField fx:id="packForgeHashField" floatingText="Modloader SHA-1 (optional for Fabric)" maxWidth="500.0"
                                  prefWidth="500.0" minHeight="48.0" prefHeight="48.0"/>

                    <!-- Images -->
                    <Label text="Images" style="-fx-font-weight: bold;">
                        <padding><Insets top="8.0"/></padding>
                        <font><Font size="14.0"/></font>
                    </Label>
                    <HBox spacing="16.0" alignment="CENTER_LEFT">
                        <VBox spacing="4.0">
                            <MFXTextField fx:id="packLogoURLField" floatingText="Logo URL" maxWidth="400.0"
                                          prefWidth="400.0" minHeight="48.0" prefHeight="48.0"/>
                            <MFXTextField fx:id="packLogoSha1Field" floatingText="Logo SHA-1" maxWidth="400.0"
                                          prefWidth="400.0" minHeight="48.0" prefHeight="48.0"/>
                        </VBox>
                        <ImageView fx:id="logoPreview" fitHeight="64.0" fitWidth="64.0" preserveRatio="true"
                                   accessibleText="Logo preview"/>
                    </HBox>
                    <HBox spacing="16.0" alignment="CENTER_LEFT">
                        <VBox spacing="4.0">
                            <MFXTextField fx:id="packBgURLField" floatingText="Background URL" maxWidth="400.0"
                                          prefWidth="400.0" minHeight="48.0" prefHeight="48.0"/>
                            <MFXTextField fx:id="packBgSha1Field" floatingText="Background SHA-1" maxWidth="400.0"
                                          prefWidth="400.0" minHeight="48.0" prefHeight="48.0"/>
                        </VBox>
                        <ImageView fx:id="bgPreview" fitHeight="64.0" fitWidth="128.0" preserveRatio="true"
                                   accessibleText="Background preview"/>
                    </HBox>

                    <!-- Scan Exclusions -->
                    <Label text="Scan Exclusions (one per line)" style="-fx-font-weight: bold;">
                        <padding><Insets top="8.0"/></padding>
                        <font><Font size="14.0"/></font>
                    </Label>
                    <TextArea fx:id="scanExclusionsArea" prefHeight="80.0" maxWidth="500.0" prefWidth="500.0"
                              promptText="e.g. mods/optifine.jar"/>
                </VBox>
            </ScrollPane>
        </Tab>
    </TabPane>

    <!-- Row 4: Bottom action bar — status text + Save/Return. Mirrors the
         Settings screen's bottom-bar pattern (primary actions right-aligned,
         contextual info on the left). -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="bottomBar" GridPane.rowIndex="4">
        <padding><Insets left="14.0" right="14.0"/></padding>
        <Label fx:id="statusLabel" text="No file loaded" styleClass="muted"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="saveBtn" prefHeight="28.0" prefWidth="80.0" text="Save"/>
        <MFXButton fx:id="returnBtn" prefHeight="28.0" prefWidth="80.0" text="Return"/>
    </HBox>
</GridPane>
