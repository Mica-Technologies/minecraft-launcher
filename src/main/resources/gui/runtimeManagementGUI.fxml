<!--
  Runtime Management — restructured to share the app-shell pattern used by
  mainGUI / library / settings / editor: top navbar (brand + title + help),
  a content card in the middle, and a bottom action bar carrying the info
  text + Return. The prior layout used three nested .settingsContainer
  boxes that looked unrelated to the rest of the app.
-->
<GridPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="475.0" minWidth="750.0"
          prefHeight="600.0" prefWidth="900.0" styleClass="rootPane"
          xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: announcement banner (conditional, 0-60 px) -->
        <RowConstraints fx:id="announcementRow" maxHeight="-Infinity" minHeight="0.0"/>
        <!-- Row 1: top navbar -->
        <RowConstraints maxHeight="52.0" minHeight="52.0" prefHeight="52.0"/>
        <!-- Row 2: content fills remaining space -->
        <RowConstraints vgrow="ALWAYS"/>
        <!-- Row 3: bottom action bar -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0"/>
    </rowConstraints>

    <!-- Row 0: Announcement -->
    <Label fx:id="announcement" alignment="CENTER" maxHeight="1.7976931348623157E308"
           maxWidth="1.7976931348623157E308" minHeight="0.0" styleClass="banner-announcement"
           text="--" wrapText="true"/>

    <!-- Row 1: Top navbar -->
    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="navBar" GridPane.rowIndex="1">
        <padding><Insets left="14.0" right="10.0"/></padding>

        <Pane prefWidth="36.0" prefHeight="36.0" minWidth="36.0" minHeight="36.0"
              maxWidth="36.0" maxHeight="36.0" styleClass="navBrandLogo">
            <fx:include source="components/micaBrandLogo-small.fxml"/>
        </Pane>
        <Label text="Runtime Management" styleClass="heading-h2"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <Label fx:id="helpBtn" text="?" styleClass="helpButton"/>
    </HBox>

    <!-- Row 2: Content card — list of installed runtimes with row of actions -->
    <VBox spacing="10.0" GridPane.rowIndex="2">
        <padding><Insets top="16.0" bottom="16.0" left="24.0" right="24.0"/></padding>

        <Label text="Installed Java Runtimes" styleClass="heading-h3"/>

        <ListView fx:id="runtimeListView" VBox.vgrow="ALWAYS"/>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" text="Select a runtime to manage it." styleClass="muted"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <MFXButton fx:id="refreshBtn" prefHeight="28.0" prefWidth="110.0" text="Refresh"/>
            <MFXButton fx:id="deleteBtn" prefHeight="28.0" prefWidth="110.0" styleClass="dangerZone"
                       text="Delete"/>
            <MFXButton fx:id="deleteAllBtn" prefHeight="28.0" prefWidth="110.0" styleClass="dangerZone"
                       text="Delete All"/>
        </HBox>
    </VBox>

    <!-- Row 3: Bottom action bar — info text on the left, Return on the right -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="bottomBar" GridPane.rowIndex="3">
        <padding><Insets left="14.0" right="14.0"/></padding>
        <Label fx:id="infoLabel" text="Runtimes are downloaded automatically when launching a modpack."
               styleClass="muted"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="returnBtn" prefHeight="28.0" prefWidth="80.0" text="Return"/>
    </HBox>
</GridPane>
