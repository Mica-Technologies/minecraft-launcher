<!--
  Game Console — restructured to share the app-shell pattern: brand-logo
  navbar carrying the dynamic title ("Game Console: <pack>" / "Game Crashed:
  <pack>") and the running/exited status on the right; content area for the
  diagnosis card + log; bottomBar with uptime + Copy/Crash Report/Kill/Close.
  No announcement banner here — the console runs while a game session is
  active and we don't want unrelated banners competing for attention.
-->
<GridPane fx:id="rootPane" minHeight="475.0" minWidth="750.0"
          prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane"
          xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: top navbar -->
        <RowConstraints maxHeight="52.0" minHeight="52.0" prefHeight="52.0"/>
        <!-- Row 1: content fills remaining -->
        <RowConstraints vgrow="ALWAYS"/>
        <!-- Row 2: bottom action bar -->
        <RowConstraints maxHeight="44.0" minHeight="44.0" prefHeight="44.0"/>
    </rowConstraints>

    <!-- Row 0: Top navbar — brand + dynamic title + status chip on the right. -->
    <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="navBar">
        <padding><Insets left="14.0" right="10.0"/></padding>

        <Pane prefWidth="36.0" prefHeight="36.0" minWidth="36.0" minHeight="36.0"
              maxWidth="36.0" maxHeight="36.0" styleClass="navBrandLogo">
            <fx:include source="components/micaBrandLogo-small.fxml"/>
        </Pane>
        <Label fx:id="titleLabel" text="%console.navbar.title" styleClass="navBrand"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <Label fx:id="statusLabel" text="%console.status.running" styleClass="muted"/>
        <Label fx:id="helpBtn" text="?" styleClass="helpButton"/>
    </HBox>

    <!-- Row 1: Content — diagnosis card stacks above the log; truncation hint sits at the bottom. -->
    <VBox spacing="8.0" GridPane.rowIndex="1">
        <padding><Insets top="14.0" bottom="6.0" left="20.0" right="20.0"/></padding>

        <!-- Crash diagnosis panel — populated by MCLauncherGameConsoleGui.showDiagnosis() -->
        <VBox fx:id="diagnosisCard" visible="false" managed="false" spacing="6.0"
              styleClass="card,crashDiagnosisCard">
            <padding><Insets top="12.0" bottom="12.0" left="14.0" right="14.0"/></padding>
            <Label fx:id="diagnosisTitleLabel" styleClass="heading-h3,crashDiagnosisTitle"/>
            <Label fx:id="diagnosisSummaryLabel" wrapText="true" styleClass="crashDiagnosisSummary"/>
            <HBox fx:id="diagnosisActionsBox" spacing="6.0" alignment="CENTER_LEFT"/>
        </VBox>

        <!-- Search / filter / auto-pin toolbar. The search field is the sole
             flexible element (grows on wide windows, shrinks under pressure);
             every other control carries minWidth="-Infinity" (USE_PREF_SIZE) so
             it keeps its full label instead of ellipsizing when space is tight. -->
        <HBox spacing="8.0" alignment="CENTER_LEFT">
            <MFXTextField fx:id="searchField" promptText="%console.search.placeholder"
                          prefHeight="26.0" prefWidth="260.0" minWidth="120.0"
                          HBox.hgrow="ALWAYS" floatMode="DISABLED"
                          styleClass="no-floating-label"/>
            <Label fx:id="searchStatusLabel" text="" styleClass="muted"
                   minWidth="-Infinity" style="-fx-font-size: 11px;"/>
            <MFXButton fx:id="searchPrevBtn" text="%console.search.prev"
                       prefHeight="26.0" minWidth="-Infinity"
                       styleClass="heroCardSecondaryBtn"/>
            <MFXButton fx:id="searchNextBtn" text="%console.search.next"
                       prefHeight="26.0" minWidth="-Infinity"
                       styleClass="heroCardSecondaryBtn"/>
            <CheckBox fx:id="autoPinCheckBox" text="%console.autoPin.label" selected="true"
                      minWidth="-Infinity"/>
        </HBox>

        <!-- Live game log / crash report text -->
        <TextArea fx:id="logArea" editable="false" wrapText="true" styleClass="text-mono"
                  style="-fx-font-size: 12px;" VBox.vgrow="ALWAYS"/>

        <!-- Truncation notice row -->
        <HBox spacing="5.0" alignment="CENTER_LEFT">
            <Label fx:id="truncationLabel" text="" visible="false" managed="false"
                   styleClass="subtle" style="-fx-font-size: 10px;"/>
            <Hyperlink fx:id="openLogLink" text="%console.openLogLink.text" visible="false" managed="false"
                       style="-fx-font-size: 10px;"/>
        </HBox>
    </VBox>

    <!-- Row 2: Bottom action bar -->
    <HBox styleClass="bottomBar" alignment="CENTER_LEFT" spacing="8.0"
          GridPane.rowIndex="2">
        <padding><Insets left="14.0" right="14.0"/></padding>
        <Label fx:id="uptimeLabel" text="" styleClass="muted"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="copyBtn" prefHeight="28.0" prefWidth="70.0" text="%console.copyBtn.label"/>
        <MFXButton fx:id="crashReportBtn" prefHeight="28.0" prefWidth="110.0"
                   text="%console.crashReportBtn.crashReport" visible="false" managed="false"/>
        <MFXButton fx:id="killBtn" prefHeight="28.0" prefWidth="100.0" styleClass="dangerZone"
                   text="%console.killBtn.label"/>
        <!-- Width sized for the longer "Return to Launcher" state the controller
             swaps in after the game exits (MCLauncherGameConsoleGui:332). The
             initial "Close" label just floats centered in the wider button while
             the game is running, which reads fine. -->
        <MFXButton fx:id="closeBtn" prefHeight="28.0" prefWidth="170.0" text="%console.closeBtn.label"/>
    </HBox>
</GridPane>
