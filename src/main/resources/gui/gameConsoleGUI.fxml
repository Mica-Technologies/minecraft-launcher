<GridPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="475.0" minWidth="750.0"
          prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane" stylesheets="@../guiStyle-dark.css"
          xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <RowConstraints vgrow="SOMETIMES"/>
    </rowConstraints>

    <GridPane styleClass="stripPane">
        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="45.0" prefHeight="45.0"/>
            <RowConstraints vgrow="ALWAYS"/>
            <RowConstraints minHeight="25.0" prefHeight="25.0"/>
            <RowConstraints minHeight="45.0" prefHeight="45.0"/>
        </rowConstraints>
        <padding>
            <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
        </padding>

        <!-- Header -->
        <GridPane GridPane.rowIndex="0">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="100.0" prefWidth="100.0"/>
            </columnConstraints>
            <Label fx:id="titleLabel" text="Game Console" GridPane.columnIndex="0">
                <font>
                    <Font name="System Bold" size="16.0"/>
                </font>
            </Label>
            <Label fx:id="statusLabel" text="Running" alignment="CENTER_RIGHT" GridPane.columnIndex="1">
                <font>
                    <Font size="12.0"/>
                </font>
            </Label>
        </GridPane>

        <!-- Log output area -->
        <TextArea fx:id="logArea" editable="false" wrapText="true" GridPane.rowIndex="1"
                  style="-fx-font-family: monospace; -fx-font-size: 11px;">
            <GridPane.margin>
                <Insets top="5.0" bottom="2.0"/>
            </GridPane.margin>
        </TextArea>

        <!-- Truncation notice row -->
        <HBox spacing="5.0" alignment="CENTER_LEFT" GridPane.rowIndex="2">
            <Label fx:id="truncationLabel" text="" visible="false" managed="false"
                   style="-fx-font-size: 10px; -fx-text-fill: #999999;">
            </Label>
            <Hyperlink fx:id="openLogLink" text="Open full log file" visible="false" managed="false"
                       style="-fx-font-size: 10px;">
            </Hyperlink>
        </HBox>

        <!-- Bottom bar -->
        <HBox styleClass="bottomBar" alignment="CENTER_LEFT" spacing="8.0" minHeight="44.0" maxHeight="44.0" prefHeight="44.0" GridPane.rowIndex="3">
            <padding>
                <Insets left="8.0" right="8.0"/>
            </padding>
            <Label fx:id="uptimeLabel" text=""/>
            <Pane HBox.hgrow="ALWAYS"/>
            <MFXButton fx:id="copyBtn" prefHeight="30.0" prefWidth="70.0" text="Copy"/>
            <MFXButton fx:id="crashReportBtn" prefHeight="30.0" prefWidth="110.0"
                       text="Crash Report" visible="false" managed="false"/>
            <MFXButton fx:id="killBtn" prefHeight="30.0" prefWidth="100.0" styleClass="dangerZone"
                       text="Kill Game"/>
            <MFXButton fx:id="closeBtn" prefHeight="30.0" prefWidth="155.0" text="Close"/>
        </HBox>
    </GridPane>
</GridPane>
