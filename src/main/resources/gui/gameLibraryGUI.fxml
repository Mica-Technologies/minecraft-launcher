<!--
  Game Library — combined replacement for the old "Edit Packs" + "Vanilla Versions"
  screens. Cards in a responsive FlowPane (smaller than the main-menu hero cards
  so more fit per row), with a top bar that filters by type + status + a free-text
  search, and a bottom bar that carries the original "Add from URL" / "Modpack Editor"
  / "Generate Manifest" actions. Cards are populated programmatically by the
  controller via LibraryCard, mirroring the main-menu pattern.
-->
<GridPane fx:id="rootPane" minHeight="475.0" minWidth="750.0"
          prefHeight="800.0" prefWidth="1000.0" styleClass="rootPane"
          xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1">
    <columnConstraints>
        <ColumnConstraints hgrow="ALWAYS"/>
    </columnConstraints>
    <rowConstraints>
        <!-- Row 0: top navbar (title + search + filters), ~80 px -->
        <RowConstraints minHeight="80.0" prefHeight="80.0" maxHeight="80.0"/>
        <!-- Row 1: announcement banner (conditional 0/40/60 px) — below the navbar
             so the chrome stays anchored at the top. -->
        <RowConstraints fx:id="announcementRow" maxHeight="-Infinity" minHeight="0.0"/>
        <!-- Row 2: pagination bar (prev / page X of Y / next + per-page selector), ~40 px -->
        <RowConstraints minHeight="40.0" prefHeight="40.0" maxHeight="40.0"/>
        <!-- Row 3: card grid (fills available space) -->
        <RowConstraints vgrow="ALWAYS"/>
        <!-- Row 4: bottom action bar (add-from-URL + editor + return), ~52 px -->
        <RowConstraints minHeight="52.0" prefHeight="52.0" maxHeight="52.0"/>
    </rowConstraints>

    <!-- Row 1: Announcement banner (below the navbar) -->
    <Label fx:id="announcement" alignment="CENTER" maxHeight="1.7976931348623157E308"
           maxWidth="1.7976931348623157E308" minHeight="0.0" styleClass="banner-announcement"
           text="--" textAlignment="CENTER" wrapText="true" GridPane.rowIndex="1"/>

    <!-- Row 0: Top navbar — title + filter controls. Label prefixes instead of MFX's
         floatingText property: floatingText renders the label inside the control's vertical
         envelope and clips when the control isn't tall enough; external labels are cleaner
         and don't fight the navbar's compact height. -->
    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="navBar">
        <padding><Insets left="14.0" right="14.0"/></padding>

        <!-- Brand lockup — matches mainGUI / settings navbars. Bounded 36×36 Pane keeps
             the pre-scaled SVG include from blowing out the bar's horizontal layout. -->
        <Pane prefWidth="36.0" prefHeight="36.0" minWidth="36.0" minHeight="36.0"
              maxWidth="36.0" maxHeight="36.0" styleClass="navBrandLogo">
            <fx:include source="components/micaBrandLogo-small.fxml"/>
        </Pane>
        <!-- Screen header: matches the navbar button on the main menu that brings
             users here. The main menu's wordmark area uses "Library" for the
             installed-packs surface, so this screen — the install / manage / browse
             surface — uses "Browse" to mirror the entry point's verb. -->
        <Label text="%browse.navbar.title" styleClass="navBrand"/>

        <Pane HBox.hgrow="ALWAYS" minWidth="20.0"/>

        <Label text="%main.filter.searchLabel" styleClass="muted"/>
        <MFXTextField fx:id="searchField" promptText="Name…" minWidth="180.0" prefWidth="200.0"
                      minHeight="32.0" prefHeight="32.0" maxHeight="32.0"
                      styleClass="no-floating-label"/>

        <Label text="%main.filter.typeLabel" styleClass="muted"/>
        <MFXComboBox fx:id="typeFilter" minWidth="150.0" prefWidth="160.0"
                     minHeight="32.0" prefHeight="32.0" maxHeight="32.0"/>

        <Label text="%browse.filter.statusLabel" styleClass="muted"/>
        <MFXComboBox fx:id="statusFilter" minWidth="120.0" prefWidth="130.0"
                     minHeight="32.0" prefHeight="32.0" maxHeight="32.0"/>

        <Label text="%main.filter.sortLabel" styleClass="muted"/>
        <MFXComboBox fx:id="sortFilter" minWidth="150.0" prefWidth="160.0"
                     minHeight="32.0" prefHeight="32.0" maxHeight="32.0"/>

        <!-- "Offline" chip — visible only when NetworkUtilities.isOffline() returns
             true. OfflineIndicator.applyTo() in the controller toggles it. Sits
             next to the help button so it's consistent across every screen. -->
        <Label fx:id="offlineLabel" text="%main.fetchLabel.offline" managed="false" visible="false"
               styleClass="chip-offline"/>

        <!-- Navbar-anchored help button, same pattern as mainGUI / settings / editor /
             runtime / console so MCLauncherGuiWindow.injectHelpButton's corner-overlay
             fallback doesn't drop it on top of the navbar at runtime. -->
        <Label fx:id="helpBtn" text="?" styleClass="helpButton"/>
    </HBox>

    <!-- Row 2: Pagination bar. Sits between the filters and the cards so the user can see
         where they are without scrolling to the bottom. Per-page selector lives on the right. -->
    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="bottomBar" GridPane.rowIndex="2">
        <padding><Insets left="20.0" right="20.0"/></padding>
        <Label fx:id="paginationRangeLabel" text="" styleClass="muted"/>
        <!-- Card-grid loading affordance: spinner + "Loading library…" shown while rebuildCards
             gathers its data off the FX thread (e.g. a cold Mojang vanilla-manifest fetch). Only
             appears if the gather is slow enough to notice; warm rebuilds never flash it. Kept
             separate from backgroundFetchLabel so an install's status text isn't clobbered. -->
        <HBox fx:id="loadingIndicator" alignment="CENTER_LEFT" spacing="6.0"
              visible="false" managed="false">
            <ProgressIndicator fx:id="loadingSpinner" visible="false"
                               prefWidth="16.0" prefHeight="16.0" maxWidth="16.0" maxHeight="16.0"/>
            <Label text="%browse.loading" styleClass="muted"/>
        </HBox>
        <!-- Shows "Loading available packs…" while the background available-modpacks fetch
             from startup is still in flight. Hidden once the future completes (the controller
             re-runs rebuildCards at that point so the new cards merge in without a manual
             refresh). Mirrors the indicator on the main menu. -->
        <Label fx:id="backgroundFetchLabel" text="%main.fetchLabel.loading"
               styleClass="muted" visible="false" managed="false"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <MFXButton fx:id="prevPageBtn" prefHeight="28.0" prefWidth="60.0" text="%main.pagination.prev"/>
        <Label fx:id="paginationPageLabel" text="Page 1 of 1" styleClass="muted"/>
        <MFXButton fx:id="nextPageBtn" prefHeight="28.0" prefWidth="70.0" text="%main.pagination.next"/>
        <Pane HBox.hgrow="SOMETIMES" minWidth="20.0"/>
        <Label text="%main.pagination.perPageLabel" styleClass="muted"/>
        <MFXComboBox fx:id="pageSizeFilter" minWidth="80.0" prefWidth="80.0"
                     minHeight="28.0" prefHeight="28.0" maxHeight="28.0"/>
    </HBox>

    <!-- Row 3: Card grid scroll pane. The controller fills cardList programmatically. -->
    <ScrollPane fx:id="libraryScrollPane" GridPane.rowIndex="3"
                fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="modpackScroll">
        <javafx.scene.layout.FlowPane fx:id="cardList" styleClass="modpackCardList"
                                      hgap="16" vgap="16" alignment="TOP_CENTER" prefWrapLength="800">
            <padding><Insets top="20.0" bottom="28.0" left="28.0" right="28.0"/></padding>
            <!-- LibraryCards inserted by MCLauncherGameLibraryGui.rebuildCards() -->
        </javafx.scene.layout.FlowPane>
    </ScrollPane>

    <!-- Row 4: Bottom action bar -->
    <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="bottomBar" GridPane.rowIndex="4">
        <padding><Insets left="12.0" right="12.0"/></padding>

        <Label text="%browse.bottomBar.urlLabel" styleClass="muted"/>
        <MFXTextField fx:id="urlAddField" promptText="Modpack manifest URL" minHeight="32.0"
                      prefHeight="32.0" prefWidth="320.0" HBox.hgrow="SOMETIMES"
                      styleClass="no-floating-label"/>
        <MFXButton fx:id="urlAddBtn" prefHeight="32.0" prefWidth="120.0" text="%browse.bottomBar.urlAddBtn"/>
        <MFXButton fx:id="importZipBtn" prefHeight="32.0" prefWidth="130.0" text="%browse.bottomBar.importZipBtn"/>
        <MFXButton fx:id="importPrismBtn" prefHeight="32.0" prefWidth="150.0"
                   text="%browse.bottomBar.importPrismBtn"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <MFXButton fx:id="editorBtn" prefHeight="32.0" prefWidth="130.0" text="%browse.bottomBar.editorBtn"/>
        <MFXButton fx:id="hostingManifestBtn" prefHeight="32.0" prefWidth="170.0"
                   text="%browse.hostingManifest.label"/>
        <MFXButton fx:id="returnBtn" prefHeight="32.0" prefWidth="80.0" text="%browse.bottomBar.returnBtn"/>
    </HBox>
</GridPane>
