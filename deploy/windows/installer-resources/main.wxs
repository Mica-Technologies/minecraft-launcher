<?xml version="1.0" encoding="utf-8"?>
<!-- Custom main.wxs for jpackage MSI installer.
     Copied from the jpackage default (JDK 25 / Corretto 25) with WixVariable
     overrides added inside Product for Minecraft-themed installer bitmaps.
     Bitmap path tokens (@@...@@) are replaced at build time by Maven antrun. -->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <?ifdef JpIsSystemWide ?>
    <?define JpInstallScope="perMachine"?>
  <?else?>
    <?define JpInstallScope="perUser"?>
  <?endif?>

  <?define JpProductLanguage=1033 ?>
  <?define JpInstallerVersion=200 ?>
  <?define JpCompressedMsi=yes ?>

  <!-- Branding metadata. The base jpackage template references these via
       ?ifdef? blocks but never defines them — jpackage doesn't expose CLI
       flags for them either, so define them here so the Add/Remove Programs
       entry has working Help / About / Update buttons. -->
  <?define JpHelpURL   = "https://github.com/Mica-Technologies/minecraft-launcher/issues" ?>
  <?define JpAboutURL  = "https://minecraft.micatechnologies.com/" ?>
  <?define JpUpdateURL = "https://github.com/Mica-Technologies/minecraft-launcher/releases" ?>

  <!-- Always allow upgrades + downgrades + same-version reinstall. jpackage's
       stock template gates this behind ?ifdef JpAllowUpgrades?, which jpackage
       never passes, so the resulting MSI refuses every reinstall + version
       transition. We always perform the upgrade (OnlyDetect=no) and always
       remove the previous install (RemoveExistingProducts below) so dev
       builds can be reinstalled without uninstalling first, and any user
       can switch between a stable and a dev build cleanly. -->

  <?include $(var.JpConfigDir)/overrides.wxi ?>

  <!-- ProductCode is intentionally randomized per build via "*" instead of
       jpackage's $(var.JpProductCode). jpackage derives JpProductCode
       deterministically from name+version (UUID.nameUUIDFromBytes of
       "ProductCode|name|version|..."), so two builds of the same dev version
       share a ProductCode. Windows Installer then rejects the second install
       as "already installed" before our Upgrade block can run — the only
       workaround was a manual uninstall.

       With "*" each build gets a fresh GUID, the existing install is found
       by UpgradeCode (which IS stable), and RemoveExistingProducts below
       cleanly removes it before laying down the new version. This restores
       same-version reinstalls + upgrades + downgrades without requiring the
       user to uninstall first. -->
  <Product
    Id="*"
    Name="$(var.JpAppName)"
    Language="$(var.JpProductLanguage)"
    Version="$(var.JpAppVersion)"
    Manufacturer="$(var.JpAppVendor)"
    UpgradeCode="$(var.JpProductUpgradeCode)">

    <Package
      Description="$(var.JpAppDescription)"
      Manufacturer="$(var.JpAppVendor)"
      InstallerVersion="$(var.JpInstallerVersion)"
      Compressed="$(var.JpCompressedMsi)"
      InstallScope="$(var.JpInstallScope)" Platform="x64"
    />

    <!-- Minecraft-themed installer UI bitmaps (absolute paths injected by Maven) -->
    <WixVariable Id="WixUIBannerBmp" Value="@@BANNER_BMP_PATH@@"/>
    <WixVariable Id="WixUIDialogBmp" Value="@@DIALOG_BMP_PATH@@"/>

    <Media Id="1" Cabinet="Data.cab" EmbedCab="yes" />

    <Upgrade Id="$(var.JpProductUpgradeCode)">
      <!-- Upgrade: any installed version <= the new version is removed and the
           new one installed. IncludeMaximum=yes catches same-version installs
           so dev-build reinstalls work without an uninstall step. -->
      <UpgradeVersion
        OnlyDetect="no"
        Property="JP_UPGRADABLE_FOUND"
        Maximum="$(var.JpAppVersion)"
        MigrateFeatures="yes"
        IncludeMaximum="yes" />
      <!-- Downgrade: any installed version > the new version is also removed
           and the older version installed. Lets users freely switch between
           a newer stable and an older dev build (or vice versa). -->
      <UpgradeVersion
        OnlyDetect="no"
        Property="JP_DOWNGRADABLE_FOUND"
        Minimum="$(var.JpAppVersion)"
        MigrateFeatures="yes"
        IncludeMinimum="no" />
    </Upgrade>

    <Binary Id="JpCaDll" SourceFile="wixhelper.dll"/>

    <CustomAction Id="JpFindRelatedProducts" BinaryKey="JpCaDll" DllEntry="FindRelatedProductsEx" />

    <!-- Standard required root -->
    <Directory Id="TARGETDIR" Name="SourceDir"/>

    <Feature Id="DefaultFeature" Title="!(loc.MainFeatureTitle)" Level="1">
      <ComponentGroupRef Id="Shortcuts"/>
      <ComponentGroupRef Id="Files"/>
      <ComponentGroupRef Id="FileAssociations"/>
      <ComponentGroupRef Id="FragmentOsCondition"/>
    </Feature>

    <CustomAction Id="JpSetARPINSTALLLOCATION" Property="ARPINSTALLLOCATION" Value="[INSTALLDIR]" />
    <CustomAction Id="JpSetARPCOMMENTS" Property="ARPCOMMENTS" Value="$(var.JpAppDescription)" />
    <CustomAction Id="JpSetARPCONTACT" Property="ARPCONTACT" Value="$(var.JpAppVendor)" />
    <CustomAction Id="JpSetARPSIZE" Property="ARPSIZE" Value="$(var.JpAppSizeKb)" />

    <?ifdef JpHelpURL ?>
      <CustomAction Id="JpSetARPHELPLINK" Property="ARPHELPLINK" Value="$(var.JpHelpURL)" />
    <?endif?>

    <?ifdef JpAboutURL ?>
      <CustomAction Id="JpSetARPURLINFOABOUT" Property="ARPURLINFOABOUT" Value="$(var.JpAboutURL)" />
    <?endif?>

    <?ifdef JpUpdateURL ?>
      <CustomAction Id="JpSetARPURLUPDATEINFO" Property="ARPURLUPDATEINFO" Value="$(var.JpUpdateURL)" />
    <?endif?>

    <?ifdef JpIcon ?>
    <Property Id="ARPPRODUCTICON" Value="JpARPPRODUCTICON"/>
    <Icon Id="JpARPPRODUCTICON" SourceFile="$(var.JpIcon)"/>
    <?endif?>

    <UIRef Id="JpUI"/>

    <InstallExecuteSequence>
      <Custom Action="JpSetARPINSTALLLOCATION" After="CostFinalize">Not Installed</Custom>
      <Custom Action="JpSetARPCOMMENTS" After="CostFinalize">Not Installed</Custom>
      <Custom Action="JpSetARPCONTACT" After="CostFinalize">Not Installed</Custom>
      <Custom Action="JpSetARPSIZE" After="CostFinalize">Not Installed</Custom>
      <?ifdef JpHelpURL ?>
        <Custom Action="JpSetARPHELPLINK" After="CostFinalize">Not Installed</Custom>
      <?endif?>
      <?ifdef JpAboutURL ?>
        <Custom Action="JpSetARPURLINFOABOUT" After="CostFinalize">Not Installed</Custom>
      <?endif?>
      <?ifdef JpUpdateURL ?>
        <Custom Action="JpSetARPURLUPDATEINFO" After="CostFinalize">Not Installed</Custom>
      <?endif?>

      <!-- Upgrades + downgrades + same-version reinstalls are always allowed
           (see Upgrade element above) — no JpDisallow* error actions here. -->
      <LaunchConditions Before="AppSearch"/>
      <RemoveExistingProducts Before="CostInitialize"/>
      <Custom Action="JpFindRelatedProducts" After="FindRelatedProducts"/>
    </InstallExecuteSequence>

    <InstallUISequence>
      <Custom Action="JpFindRelatedProducts" After="FindRelatedProducts"/>
    </InstallUISequence>

  </Product>
</Wix>
