<?xml version="1.0" ?>
<!--
  Custom Info.plist template for jpackage's --resource-dir hook.

  Mirrors the default jpackage template (DEPLOY_* placeholders are string-replaced
  by jpackage at build time) plus a CFBundleURLTypes block that registers the
  mmcl:// URL scheme with macOS Launch Services. Without this, the website's
  "Open in Desktop Launcher" buttons can't deep-link into the launcher on macOS
  via cold start — they only reach an already-running launcher through the
  Desktop.setOpenURIHandler bridge wired in SystemMenuBarManager.

  The DEPLOY_FILE_ASSOCIATIONS placeholder is intentionally preserved so the
  existing --file-associations flag in the pom keeps injecting the .mmcjson
  CFBundleDocumentTypes block right above the URL types.

  If a future jpackage version renames any of the DEPLOY_* placeholders the
  build will fail loudly; re-sync from the OpenJDK source:
    src/jdk.jpackage/macosx/classes/jdk/jpackage/internal/resources/Info.plist.template
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
 <dict>
  <key>LSMinimumSystemVersion</key>
  <string>10.9</string>
  <key>CFBundleDevelopmentRegion</key>
  <string>English</string>
  <key>CFBundleAllowMixedLocalizations</key>
  <true/>
  <key>CFBundleExecutable</key>
  <string>DEPLOY_LAUNCHER_NAME</string>
  <key>CFBundleIdentifier</key>
  <string>DEPLOY_BUNDLE_IDENTIFIER</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>DEPLOY_BUNDLE_NAME</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>DEPLOY_BUNDLE_SHORT_VERSION</string>
  <key>LSApplicationCategoryType</key>
  <string>DEPLOY_BUNDLE_CATEGORY</string>
  <key>CFBundleVersion</key>
  <string>DEPLOY_BUNDLE_CFBUNDLE_VERSION</string>
  <key>NSHumanReadableCopyright</key>
  <string>DEPLOY_BUNDLE_COPYRIGHT</string>
  <key>CFBundleIconFile</key>
  <string>DEPLOY_ICON_FILE</string>
DEPLOY_FILE_ASSOCIATIONS
  <!-- Custom: mmcl:// URL scheme registration with Launch Services.
       CFBundleURLName is the user-facing protocol description shown in
       "Choose Application" dialogs. CFBundleTypeRole=Viewer indicates the
       launcher is the primary handler for the scheme but not the only one;
       a future "edit" tool could register the same scheme with role=Editor
       without conflict. -->
  <key>CFBundleURLTypes</key>
  <array>
   <dict>
    <key>CFBundleURLName</key>
    <string>Mica Minecraft Launcher Protocol</string>
    <key>CFBundleURLSchemes</key>
    <array>
     <string>mmcl</string>
    </array>
    <key>CFBundleTypeRole</key>
    <string>Viewer</string>
   </dict>
  </array>
  <key>NSHighResolutionCapable</key>
  <true/>
  <key>NSSupportsAutomaticGraphicsSwitching</key>
  <true/>
 </dict>
</plist>
